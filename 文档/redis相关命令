cat /var/log/redis/redis-server.log

启用AOF重写（Auto Rewrite）
在redis.conf添加
auto-aof-rewrite-percentage 100
auto-aof-rewrite-min-size 64mb

# 创建systemd覆盖目录
sudo systemctl edit redis-server

[Service]
ExecStartPre=/bin/sh -c 'if [ -f /var/lib/redis/appendonly.aof ];then /usr/bin/redis-check-aof --fix /var/lib/redis/appendonly.aof <<< "y";fi'

sudo systemctl daemon-reload
sudo systemctl restart redis

ls -lh /var/lib/redis/

# 监控是否加载完毕
redis-cli INFO persistence
# 检查 Redis 日志
# 查看 Redis 启动日志（通常在 /var/log/redis/redis-server.log 或 systemd 日志
sudo journalctl -u redis-server -f

# 查看最大 keys
redis-cli --bigkeys

# 查看内存使用分布
redis-cli INFO memory
redis-cli MEMORY USAGE your_large_key  # 替换为实际 key

